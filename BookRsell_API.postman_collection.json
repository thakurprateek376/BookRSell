{
  "info": {
    "name": "BookRsell API",
    "description": "Second-hand Book Marketplace API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"city\": \"Delhi\",\n  \"role\": \"seller\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/books?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["books"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "category",
                  "value": "Engineering",
                  "disabled": true
                },
                {
                  "key": "city",
                  "value": "Delhi",
                  "disabled": true
                },
                {
                  "key": "minPrice",
                  "value": "0",
                  "disabled": true
                },
                {
                  "key": "maxPrice",
                  "value": "1000",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "java",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Book Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/books/{book_id}",
              "host": ["{{base_url}}"],
              "path": ["books", "{book_id}"]
            }
          }
        },
        {
          "name": "Add Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Advanced Java",
                  "type": "text"
                },
                {
                  "key": "author",
                  "value": "Herbert Schildt",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "250",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "Engineering",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Used once, very good condition",
                  "type": "text"
                },
                {
                  "key": "city",
                  "value": "Delhi",
                  "type": "text"
                },
                {
                  "key": "condition",
                  "value": "Very Good",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "disabled": true
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/books",
              "host": ["{{base_url}}"],
              "path": ["books"]
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Advanced Java",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "300",
                  "type": "text"
                },
                {
                  "key": "condition",
                  "value": "Good",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/books/{book_id}",
              "host": ["{{base_url}}"],
              "path": ["books", "{book_id}"]
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/books/{book_id}",
              "host": ["{{base_url}}"],
              "path": ["books", "{book_id}"]
            }
          }
        },
        {
          "name": "Get My Ads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/books/seller/myads",
              "host": ["{{base_url}}"],
              "path": ["books", "seller", "myads"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"city\": \"Mumbai\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "Get Seller Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/{user_id}",
              "host": ["{{base_url}}"],
              "path": ["users", "{user_id}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
